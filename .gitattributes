# Treat these as binary so Git never applies line-ending conversion
*.pdf  binary
*.zip  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ogg  binary
*.wav  binary

# Source files: normalize to LF in the repo
*.py  text eol=lf
*.md  text
*.txt text
# Windows batch files must keep CRLF
*.bat text eol=crlf
